# MongoDB connection string (e.g. MongoDB Atlas)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/invoices?retryWrites=true&w=majority

# Port the API listens on (hosting platforms set this automatically)
PORT=5000

# Your deployed frontend URL — used for CORS
FRONTEND_URL=https://your-frontend.vercel.app

# Secret token to protect the /api/seed endpoint
# Set to any long random string; send it as the X-Seed-Secret header when seeding
SEED_SECRET=replace-with-a-long-random-secret
